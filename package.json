{
  "name": "apiforge",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade API SDK generator platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:generate": "cd apps/api-server && pnpm prisma generate",
    "db:push": "cd apps/api-server && pnpm prisma db push",
    "db:studio": "cd apps/api-server && pnpm prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
