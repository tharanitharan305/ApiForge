import 'package:dio/dio.dart';

class NormalizedResponse<T> {
  final bool success;
  final int statusCode;
  final String message;
  final T? data;
  final dynamic raw;

  NormalizedResponse({
    required this.success,
    required this.statusCode,
    required this.message,
    this.data,
    this.raw,
  });
}

{{#if requestBody.length}}
class {{pascalCase name}}Request {
{{#each requestBody}}
  final {{#eq type 'string'}}String{{/eq}}{{#eq type 'number'}}num{{/eq}}{{#eq type 'boolean'}}bool{{/eq}}{{#eq type 'object'}}Map<String, dynamic>{{/eq}}{{#eq type 'array'}}List<dynamic>{{/eq}}{{#unless required}}?{{/unless}} {{camelCase key}};
{{/each}}

  {{pascalCase name}}Request({
{{#each requestBody}}
    {{#if required}}required {{/if}}this.{{camelCase key}},
{{/each}}
  });

  Map<String, dynamic> toJson() => {
{{#each requestBody}}
    '{{key}}': {{camelCase key}},
{{/each}}
  };
}
{{/if}}

class {{pascalCase name}}Api {
  static Dio? _dio;

  static Dio _getDio() {
    if (_dio == null) {
      final baseUrl = const String.fromEnvironment('ENV') == 'production'
          ? '{{environments.production}}'
          : '{{environments.local}}';

      _dio = Dio(BaseOptions(
        baseUrl: baseUrl,
        connectTimeout: const Duration(milliseconds: {{or timeout 30000}}),
        receiveTimeout: const Duration(milliseconds: {{or timeout 30000}}),
        headers: {
          'Content-Type': 'application/json',
          {{#each headers}}
          '{{@key}}': '{{this}}',
          {{/each}}
        },
      ));
    }
    return _dio!;
  }

  /// {{name}} - {{method}} {{endpoint}}
  {{#if description}}/// {{description}}{{/if}}
  static Future<NormalizedResponse> {{camelCase name}}({{#if requestBody.length}}
    {{pascalCase name}}Request request,{{/if}}{{#if queryParams.length}}
    Map<String, dynamic>? queryParameters,{{/if}}
  ) async {
    try {
      final dio = _getDio();
      
      final response = await dio.{{lowercase method}}(
        '{{endpoint}}',
        {{#if requestBody.length}}data: request.toJson(),{{/if}}
        {{#if queryParams.length}}queryParameters: queryParameters,{{/if}}
      );

      return _normalizeResponse(response);
    } on DioException catch (e) {
      if (e.response != null) {
        return _normalizeResponse(e.response!);
      }
      
      return NormalizedResponse(
        success: false,
        statusCode: 0,
        message: e.message ?? 'Network error',
        data: null,
        raw: e,
      );
    } catch (e) {
      return NormalizedResponse(
        success: false,
        statusCode: 0,
        message: e.toString(),
        data: null,
        raw: e,
      );
    }
  }

  static NormalizedResponse _normalizeResponse(Response response) {
    final data = response.data;
    
    // Extract values using response mapping paths
    final success = _getValueByPath(data, '{{responseMapping.successPath}}') ?? 
                   (response.statusCode != null && response.statusCode! >= 200 && response.statusCode! < 300);
    final message = _getValueByPath(data, '{{responseMapping.messagePath}}') ?? response.statusMessage ?? '';
    final responseData = _getValueByPath(data, '{{responseMapping.dataPath}}') ?? data;
    final statusCode = {{#if responseMapping.statusCodePath}}_getValueByPath(data, '{{responseMapping.statusCodePath}}') ?? {{/if}}response.statusCode ?? 0;

    return NormalizedResponse(
      success: success is bool ? success : false,
      statusCode: statusCode is int ? statusCode : 0,
      message: message.toString(),
      data: responseData,
      raw: data,
    );
  }

  static dynamic _getValueByPath(dynamic obj, String path) {
    final keys = path.split('.');
    dynamic current = obj;
    
    for (final key in keys) {
      if (current is Map) {
        current = current[key];
      } else {
        return null;
      }
    }
    
    return current;
  }
}
