{{/each}}
}
{{/if}}

/**
 * {{pascalCase name}} API Service
 */
export class {{pascalCase name}} {
  private static axiosInstance: AxiosInstance;

  private static getAxiosInstance(): AxiosInstance {
    if (!this.axiosInstance) {
      const baseURL = {{#if overrideBaseUrl}}'{{overrideBaseUrl}}'{{else}}process.env.NODE_ENV === 'production' 
          ? '{{project.productionBaseUrl}}'
          : '{{project.localBaseUrl}}'{{/if}};
      
      this.axiosInstance = axios.create({
        baseURL,
        timeout: {{or timeout 30000}},
        headers: {
          'Content-Type': 'application/json',
          {{#each headers}}
          '{{@key}}': '{{this}}',
          {{/each}}
        },
      });
    }
    return this.axiosInstance;
  }

  /**
   * {{name}} - {{method}} {{endpoint}}
   {{#if description}}* {{description}}{{/if}}
   */
  static async {{camelCase name}}({{#if requestBody.length}}
    body: {{pascalCase name}}Body{{#if queryParams.length}},{{/if}}{{/if}}{{#if queryParams.length}}
    params?: {{pascalCase name}}Params{{/if}}{{#if (or requestBody.length queryParams.length)}},{{/if}}
    config?: AxiosRequestConfig
  ): Promise<NormalizedResponse> {
    try {
      const instance = this.getAxiosInstance();
      
      const response: AxiosResponse = await instance.{{lowercase method}}(
        '{{endpoint}}'{{#if requestBody.length}},
        body{{/if}}{{#if queryParams.length}},
        { ...config, params }{{else}}{{#if requestBody.length}},
        config{{else}},
        config{{/if}}{{/if}}
      );

      return this.normalizeResponse(response);
    } catch (error: any) {
      if (error.response) {
        return this.normalizeResponse(error.response);
      }
      
      return {
        success: false,
        statusCode: 0,
        message: error.message || 'Network error',
        data: null,
        raw: error,
      };
    }
  }

  private static normalizeResponse(response: AxiosResponse): NormalizedResponse {
    const data = response.data;
    
    // Extract values using response mapping paths
    const success = this.getValueByPath(data, '{{responseMapping.successPath}}') ?? (response.status >= 200 && response.status < 300);
    const message = this.getValueByPath(data, '{{responseMapping.messagePath}}') ?? response.statusText;
    const responseData = this.getValueByPath(data, '{{responseMapping.dataPath}}') ?? data;
    const statusCode = {{#if responseMapping.statusCodePath}}this.getValueByPath(data, '{{responseMapping.statusCodePath}}') ?? {{/if}}response.status;

    return {
      success: Boolean(success),
      statusCode: Number(statusCode),
      message: String(message),
      data: responseData,
      raw: data,
    };
  }

  private static getValueByPath(obj: any, path: string): any {
    return path.split('.').reduce((current, key) => current?.[key], obj);
  }
}
