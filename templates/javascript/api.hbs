/**
 * {{name}} API
 * {{#if description}}{{description}}{{/if}}
 * Generated by ApiForge
 */

const axios = require('axios');

let axiosInstance = null;

function getAxiosInstance() {
  if (!axiosInstance) {
    axiosInstance = axios.create({
      baseURL: process.env.NODE_ENV === 'production' 
        ? '{{environments.production}}'
        : '{{environments.local}}',
      timeout: {{or timeout 30000}},
      headers: {
        'Content-Type': 'application/json',
        {{#each headers}}
        '{{@key}}': '{{this}}',
        {{/each}}
      },
    });
  }
  return axiosInstance;
}

/**
 * {{name}} - {{method}} {{endpoint}}
 {{#if description}}* {{description}}{{/if}}
 */
async function {{camelCase name}}({{#if requestBody.length}}request, {{/if}}{{#if queryParams.length}}params, {{/if}}config) {
  try {
    const instance = getAxiosInstance();
    
    const response = await instance.{{lowercase method}}(
      '{{endpoint}}'{{#if requestBody.length}},
      request{{/if}}{{#if queryParams.length}},
      { ...config, params }{{else}}{{#unless requestBody.length}},
      config{{/unless}}{{/if}}
    );

    return normalizeResponse(response);
  } catch (error) {
    if (error.response) {
      return normalizeResponse(error.response);
    }
    
    return {
      success: false,
      statusCode: 0,
      message: error.message || 'Network error',
      data: null,
      raw: error,
    };
  }
}

function normalizeResponse(response) {
  const data = response.data;
  
  // Extract values using response mapping paths
  const success = getValueByPath(data, '{{responseMapping.successPath}}') ?? (response.status >= 200 && response.status < 300);
  const message = getValueByPath(data, '{{responseMapping.messagePath}}') ?? response.statusText;
  const responseData = getValueByPath(data, '{{responseMapping.dataPath}}') ?? data;
  const statusCode = {{#if responseMapping.statusCodePath}}getValueByPath(data, '{{responseMapping.statusCodePath}}') ?? {{/if}}response.status;

  return {
    success: Boolean(success),
    statusCode: Number(statusCode),
    message: String(message),
    data: responseData,
    raw: data,
  };
}

function getValueByPath(obj, path) {
  return path.split('.').reduce((current, key) => current?.[key], obj);
}

module.exports = {
  {{camelCase name}},
};
