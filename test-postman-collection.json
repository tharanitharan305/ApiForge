{
  "info": {
    "name": "Bi Intelligence API",
    "description": "API for Business Intelligence Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Session",
      "description": "Session management endpoints",
      "item": [
        {
          "name": "Start Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIdRef\": \"58f0b5\",\n  \"platform\": \"web\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5050/v1/api/session/start",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5050",
              "path": ["v1", "api", "session", "start"]
            }
          }
        },
        {
          "name": "End Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"abc123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5050/v1/api/session/end",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5050",
              "path": ["v1", "api", "session", "end"]
            }
          }
        },
        {
          "name": "Heartbeat",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5050/v1/api/session/heartbeat?sessionId=abc123",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5050",
              "path": ["v1", "api", "session", "heartbeat"],
              "query": [
                {
                  "key": "sessionId",
                  "value": "abc123"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Authentication endpoints",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secret123\",\n  \"rememberMe\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5050/v1/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5050",
              "path": ["v1", "api", "auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5050/v1/api/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5050",
              "path": ["v1", "api", "auth", "logout"]
            }
          }
        }
      ]
    }
  ]
}
